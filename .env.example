# ════════════════════════════════════════════════════════════════════════════
# NexusLedger — Environment Configuration Template
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.  Lines prefixed with `#` are
# comments.  Variables shown with a value reflect a sensible default; uncomment
# and change only what you need to override.
#
# Generate secrets with:
#   Unix     :  openssl rand -base64 32
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# ════════════════════════════════════════════════════════════════════════════


# ── API Server ──────────────────────────────────────────────────────────────
# Core HTTP/AXUM server settings.
# Source: nexus-core/src/api/mod.rs → ApiConfig::from_env()
API_HOST=127.0.0.1
API_PORT=4000                       # code default: 8080
JWT_SECRET=                         # REQUIRED — generate with `openssl rand -base64 32`
                                    # an insecure placeholder is used if unset (NOT for production)
# API_ENABLE_HTTPS=false            # toggle TLS termination
# API_SSL_CERT_PATH=                # path to TLS certificate (PEM) — required when HTTPS is on
# API_SSL_KEY_PATH=                 # path to TLS private key  (PEM) — required when HTTPS is on
# API_CORS_ORIGINS=*                # comma-separated allowed origins, e.g. https://app.local,https://api.local
# API_RATE_LIMIT=100                # global requests/minute fallback for unauthenticated clients
# API_TIMEOUT=30                    # request timeout in seconds


# ── Per-Role Rate Limiting ──────────────────────────────────────────────────
# Requests per minute per role.  These override the code defaults only when set.
# Source: nexus-core/src/api/middleware.rs → RateLimitConfig::from_env()
# RATE_LIMIT_ADMIN=1000
# RATE_LIMIT_MANAGER=500
# RATE_LIMIT_USER=100
# RATE_LIMIT_VIEWER=50
# RATE_LIMIT_GUEST=20


# ── Database (SurrealDB) ────────────────────────────────────────────────────
# Leave empty for the embedded in-memory `kv-mem` engine (development / tests).
# For a remote SurrealDB instance, set a WebSocket URL, e.g. ws://localhost:8000
# (remote WS wiring is pending — see nexus-core/src/database/mod.rs).
DATABASE_URL=


# ── Edge / Offline ──────────────────────────────────────────────────────────
# Local SQLite cache, sync engine, lz4 compression, and AES-256-GCM encryption.
# Source: nexus-core/src/edge/mod.rs → EdgeConfig::from_env()
EDGE_ENABLED=false
EDGE_STORAGE_PATH=./data/edge
EDGE_SYNC_INTERVAL=300              # seconds between sync attempts
EDGE_OFFLINE_MODE=false
EDGE_MAX_STORAGE_SIZE_MB=1024
EDGE_COMPRESS_DATA=true
EDGE_ENCRYPT_DATA=true              # code default: false — set `true` in production


# ── Monitoring ──────────────────────────────────────────────────────────────
# System metrics, health checks, and Prometheus export.
# Source: nexus-core/src/monitor/mod.rs → MonitorConfig::from_env()
MONITOR_ENABLED=true
MONITOR_COLLECTION_INTERVAL=60      # seconds between metric collections
MONITOR_RETENTION_HOURS=24
MONITOR_ENABLE_PROMETHEUS=true      # code default: false — set `true` to expose /metrics
MONITOR_PROMETHEUS_PORT=9090
# MONITOR_ENABLE_LOGGING=true       # structured log emission toggle
MONITOR_LOG_LEVEL=info              # trace | debug | info | warn | error


# ── Logging ─────────────────────────────────────────────────────────────────
# tracing-subscriber EnvFilter reads RUST_LOG.
# Source: nexus-core/src/main.rs → EnvFilter::from_default_env()
# Examples: info,nexus_core=debug  |  warn  |  nexus_core::api=trace
# RUST_LOG=info


# ── AI Pipeline — General (local LLM via Ollama / llama-cpp-rs) ─────────────
# Source: nexus-core/src/ai/mod.rs → AiConfig::from_env()
# AI_ENABLED=true
# OLLAMA_URL=http://localhost:11434
# AI_DEFAULT_MODEL=llama3
# AI_EMBEDDING_MODEL=llama3
# AI_CLASSIFICATION_MODEL=llama3
# AI_EXTRACTION_MODEL=llama3
# AI_TIMEOUT=30                     # seconds
# AI_MAX_TOKENS=2048
# AI_TEMPERATURE=0.7


# ── AI Pipeline — Mistral OCR (PDF document ingestion) ──────────────────────
# Source: nexus-core/src/ai/ocr.rs → OcrConfig::from_env()
# NOTE: the API-key variable is MISTRAL_API_KEY (not MISTRAL_OCR_API_KEY).
MISTRAL_API_KEY=                    # required for PDF OCR (Mistral OCR4 API)
# MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
# MISTRAL_OCR_TIMEOUT=30            # seconds
# MISTRAL_OCR_ENABLED=true


# ── AI Pipeline — Local GGUF Models (llama-cpp-rs inference) ────────────────
# Filesystem path to a local GGUF model for classification / anomaly analysis.
# Leave unset to use rule-based fallbacks (no CPU/GPU inference).
GGUF_MODEL_PATH=
# Recommended models (download separately):
#   Mistral GGUF : C:\Users\msira\Downloads\Self_Healing_Python_Architect\mistral.gguf
#   Qwen3-4B GGUF: C:\Users\msira\Downloads\aletheia_gauntlet\models\Qwen3-4B-Q8_0.gguf
