# NexusLedger .gitignore
# Author: Mounir Siraji <mounir@richdaleai.com>
# License: Apache-2.0

# Build artifacts
target/
*.rs.bk

# Cargo lock files (optional - some prefer to commit these)
# Cargo.lock

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db

# Log files
data/logs/*.log
*.log

# Environment files
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp

# Data directories (optional - some prefer to commit these)
# data/

# Configuration files (optional - some prefer to commit these)
# config/

# Dependency directories
vendor/

# Test coverage
coverage/
*.lcov

# Benchmark results
bench/
*.bench

# Documentation build
.doc/
